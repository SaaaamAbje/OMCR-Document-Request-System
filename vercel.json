{
  "builds": [
    { "src": "main.py", "use": "@vercel/python" },
    { "src": "omcr-portal.html", "use": "@vercel/static" },
    { "src": "omcr-admin.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "main.py" },
    { "src": "/admin", "dest": "omcr-admin.html" },
    { "src": "/(.*)", "dest": "omcr-portal.html" }
  ]
}